{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron starten",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "program": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": ["."],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "sourceMaps": true
    }
  ]
}
