{
  "name": "mc-manager",
  "version": "1.0.0",
  "description": "Minecraft Server Manager",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.maggus.mcmanager",
    "productName": "MC Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "pidusage": "^4.0.1",
    "rcon-client": "^4.2.4"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.3"
  }
}
